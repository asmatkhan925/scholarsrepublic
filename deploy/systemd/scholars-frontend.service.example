[Unit]
Description=Scholars Republic Next.js Frontend
After=network.target scholars-backend.service

[Service]
User=scholarsrepublic
WorkingDirectory=/home/scholarsrepublic/scholarsrepublic/frontend
ExecStart=/usr/bin/npm run start
Restart=always
Environment=NODE_ENV=production
Environment=PORT=3000

[Install]
WantedBy=multi-user.target
